[INTERSECTION, DIRECTION]

SignalColor ::= red | yellow | green

TrafficSystemState
------------------
signals: DIRECTION → SignalColor
trafficDensity: DIRECTION → ℕ
emergencyMode: BOOL
signalTimers: DIRECTION → ℕ

∀ d1, d2: DIRECTION • 
    d1 ≠ d2 ∧ signals(d1) = green ⇒ signals(d2) ≠ green

∀ d: DIRECTION • signalTimers(d) ≥ 10 ∧ signalTimers(d) ≤ 120

emergencyMode = TRUE ⇒ ∃ d: DIRECTION • signals(d) = green